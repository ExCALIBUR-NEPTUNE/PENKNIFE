<?xml version="1.0" encoding="utf-8" ?>
<NEKTAR>

    <COLLECTIONS DEFAULT="MatrixFree" />

    <!--
        The composite index for the domain is expected to be 0 if the mesh was generated from the included .geo file
     -->
    <EXPANSIONS>
       <E COMPOSITE="C[0]" NUMMODES="4" TYPE="MODIFIED" FIELDS="n" />
    </EXPANSIONS>

    <CONDITIONS>
        <SOLVERINFO>
            <I PROPERTY="EQTYPE"                       VALUE="SingleDiffusiveField"/>
            <I PROPERTY="PARTTYPE"                      VALUE="ReactionSystem"/>
            <I PROPERTY="Projection"                   VALUE="Continuous" />
            <!-- <I PROPERTY="LinSysIterSolverTypeInNonlin" VALUE="GMRES"         /> -->
            <!-- <I PROPERTY="UpwindType"                   VALUE="Upwind"        /> -->
            <I PROPERTY="DiffusionAdvancement"          VALUE="Implicit"/>
        </SOLVERINFO>
        <TIMEINTEGRATIONSCHEME>
            <METHOD> IMEX </METHOD>
            <ORDER> 2 </ORDER>
        </TIMEINTEGRATIONSCHEME>

        <PARAMETERS>
            <!-- Timestepping and output options -->
            <P> TimeStep      = 5            </P>
            <P> NumSteps      = 300              </P>
            <P> TFinal        = NumSteps*TimeStep </P>
            <P> IO_InfoSteps  = 10     </P>
            <P> IO_CheckSteps = 10     </P>
            <P> particle_output_freq = 1          </P>

            <P> epsilon         = 1.0   </P>
            <!-- Anisotropic diffusion -->
            <P> lambda    = 13          </P>
            <P> k_c       = 3.19        </P>
            <P> T_bg      = 10         </P>

            <P> k_par           = 1e-3   </P>
            <P> k_perp          = 1e-6   </P>
            <P> TCore           = 300.0 </P>
            <P> T_bnd            = 1.0 </P>

            <!-- Scaling factor for ICs -->
            <P> rc = 2 </P>
            <P> yc = 0 </P>                     
            <P> rs = 0.75 </P>
            <P> ys = 0 </P>
            <P> sr = 0.1 </P>
            <P> sy = 0.1 </P>
            
            <!-- Implicit solve params -->
            <P> IterativeSolverTolerance  = 1.0E-8  </P>
            <P> NekNonlinSysMaxIterations = 30       </P>
            <P> NewtonRelativeIteTol      = 1.0E-10  </P>
            <P> NonlinIterTolRelativeL2   = 1.0E-10  </P>
            <P> LinSysRelativeTolInNonlin = 1.0E-02  </P>

            <P> num_particles_total = 1 </P>
        </PARAMETERS>

        <VARIABLES>
            <V ID="0"> n  </V>
        </VARIABLES>

        <BOUNDARYREGIONS>
            <B ID="1"> C[1] </B> <!-- Inner -->
            <B ID="2"> C[2] </B> <!-- Outer -->
        </BOUNDARYREGIONS>
        <BOUNDARYCONDITIONS>
            <REGION REF="1">
                <N VAR="n"  VALUE="0.0" />
            </REGION>
            <REGION REF="2">
                <N VAR="n"  VALUE="0.0" />
            </REGION>
        </BOUNDARYCONDITIONS>

        <FUNCTION NAME="InitialConditions">
            <E VAR="n"  DOMAIN="0" VALUE="0.1+0.1*exp((-(x-rc-rs)*(x-rc-rs)/(sr*sr))+(-(y-yc-ys)*(y-yc-ys)/(sy*sy)))" />
        </FUNCTION>
        <FUNCTION NAME="MagneticField">
            <E VAR="Bx" VALUE="(y-yc)/sqrt((x-rc)*(x-rc)+(y-yc)*(y-yc))" />
            <E VAR="By" VALUE="-(x-rc)/sqrt((x-rc)*(x-rc)+(y-yc)*(y-yc))" />
            <E VAR="Bz" VALUE="0" />
        </FUNCTION>
    </CONDITIONS>
    <NESO>
        <SPECIES>
            <I NAME="D+" FIELDS="n">
                <P> Mass = 1.0 </P>
                <P> Charge = 1.0 </P>
                <FUNCTION NAME="InitialConditions">
                    <E VAR="n"  DOMAIN="0" VALUE="1+0.1*exp((-(x-rc-rs)*(x-rc-rs)/(sr*sr))+(-(y-yc-ys)*(y-yc-ys)/(sy*sy)))" />
                </FUNCTION>
            </I>
            <I NAME="T+" FIELDS="n">
                <P> Mass = 1.0 </P>
                <P> Charge = 1.0 </P>
                <FUNCTION NAME="InitialConditions">
                    <E VAR="n"  DOMAIN="0" VALUE="1+0.1*exp((-(x-rc-rs)*(x-rc-rs)/(sr*sr))+(-(y-yc-ys)*(y-yc-ys)/(sy*sy)))" />
                </FUNCTION>
            </I>
            <KN NAME="D">
                <P> Mass = 2.0 </P>
                <INITIAL N="1000">
                    <E VAR="W" VALUE="0.00005"/>
                    <E VAR="X" VALUE="2.75"/>
                    <E VAR="Y" VALUE="0"/>
                    <!-- <E VAR="n" VALUE="sin(4*x)*sin(4*x)"/> -->
                    <E VAR="Vin" VALUE="0.00001"/>
                </INITIAL>
                <!-- <SOURCES>
                    <P N="100">
                        <E VAR="W" VALUE="0.00005"/>
                        <E VAR="X" VALUE="2.75"/>
                        <E VAR="Y" VALUE="0"/>
                        <E VAR="Tin" VALUE="1"/>
                        <E VAR="n" VALUE="exp((-(x-2-0.75*cos(150*t))*(x-2-0.75*cos(150*t))/(0.01))+(-(y-0.75*sin(150*t))*(y-0.75*sin(150*t))/(0.01)))"/>
                    </P>
                </SOURCES> -->
            </KN>
            <KN NAME="T">
                <P> Mass = 3.0 </P>
                <INITIAL N="1000">
                    <E VAR="W" VALUE="0.00005"/>
                    <E VAR="X" VALUE="2.75"/>
                    <E VAR="Y" VALUE="0"/>
                    <E VAR="Vin" VALUE="0.00001"/>

                </INITIAL>
                <!-- <SOURCES>
                    <P N="100">
                        <E VAR="W" VALUE="0.00005"/>
                        <E VAR="X" VALUE="2.75"/>
                        <E VAR="Y" VALUE="0"/>
                        <E VAR="Tin" VALUE="1"/>
                        <E VAR="n" VALUE="exp((-(x-2-0.75*cos(150*t))*(x-2-0.75*cos(150*t))/(0.01))+(-(y-0.75*sin(150*t))*(y-0.75*sin(150*t))/(0.01)))"/>
                    </P>
                </SOURCES> -->
            </KN>
        </SPECIES>
        <VANTAGE>
            <!-- <R TYPE="Ionisation" SPECIES="D">
                <RATE TYPE="AMJUEL" VALUE="1.0"/>
                <CROSSSECTION TYPE="Constant" VALUE="1.0"/>
            </R>
            <R TYPE="Ionisation" SPECIES="T">
                <RATE TYPE="AMJUEL" VALUE="1.0"/>
                <CROSSSECTION TYPE="Constant" VALUE="1.0"/>
            </R> -->
            <!-- <R TYPE="Recombination" SPECIES="0">
                <RATE TYPE="AMJUEL" VALUE="1.0"/>
                <CROSSSECTION TYPE="Constant" VALUE="1.0"/>
            </R>
            <R ID="3" TYPE="Recombination" SPECIES="1">
                <RATE TYPE="AMJUEL" VALUE="1.0"/>
                <CROSSSECTION TYPE="Constant" VALUE="1.0"/>
            </R> -->
            <!-- <R ID="4" TYPE="ChargeExchange" SPECIES="0,1">
                <RATE TYPE="Fixed" VALUE="1.0"/>
                <CROSSSECTION TYPE="Constant" VALUE="1.0"/>
            </R>
            <R ID="5" TYPE="ChargeExchange" SPECIES="1,0">
                <RATE TYPE="Fixed" VALUE="1.0"/>
                <CROSSSECTION TYPE="Constant" VALUE="1.0"/>
            </R> -->
            <S TYPE="Specular" SPECIES="D,T">
                <REGION REF="1,2"/>
                <RATE TYPE="Constant" VALUE="1.0"/>
            </S>
        </VANTAGE>
    </NESO>
</NEKTAR>
