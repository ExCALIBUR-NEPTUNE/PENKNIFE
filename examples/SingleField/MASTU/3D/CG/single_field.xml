<?xml version="1.0" encoding="utf-8" ?>
<NEKTAR>

    <COLLECTIONS DEFAULT="MatrixFree" />

    <!--
        The composite index for the domain is expected to be 0 if the mesh was generated from the included .geo file
     -->
    <EXPANSIONS>
       <E COMPOSITE="C[1]" NUMMODES="4" TYPE="MODIFIED" FIELDS="n" />
    </EXPANSIONS>

    <CONDITIONS>
        <SOLVERINFO>
            <I PROPERTY="EQTYPE"                       VALUE="SingleDiffusiveField"/>
            <I PROPERTY="Projection"                   VALUE="Continuous" />
            <I PROPERTY="LinSysIterSolverTypeInNonlin" VALUE="GMRES"         />
            <I PROPERTY="Preconditioner"               VALUE="Diagonal"/>
            <I PROPERTY="DiffusionAdvancement"          VALUE="Implicit"/>
        </SOLVERINFO>
        <TIMEINTEGRATIONSCHEME>
            <METHOD> IMEX </METHOD>
            <ORDER> 2 </ORDER>
        </TIMEINTEGRATIONSCHEME>
        <FILTER TYPE="Checkpoint">  
            <PARAM NAME="OutputFrequency">1</PARAM> 
        </FILTER> 
        <PARAMETERS>
            <!-- Conversion of mesh unit to m -->
            <P> mesh_length = 1</P> 
            <!-- Normalised temperature in eV -->
            <P> Tnorm = 1</P>
            <!-- Normalised density in m^-3 -->
            <P> Nnorm = 1e18</P>
            <!-- Normalised magnetic field in T -->
            <P> Bnorm = 1.0</P>
            <!-- Time step in cyclotron units -->
            <P> TimeStep       = 0.01               </P>
            <P> NumSteps      = 10              </P>
            <P> TFinal        = NumSteps*TimeStep </P>
            <P> IO_InfoSteps   = 1                </P>
            <!-- Coulomb logarithm -->
            <P> lambda    = 13          </P>
            <P> k_c       = 3.19        </P>
            <!-- <P> k_par       = 100000        </P> -->
            <!-- <P> k_perp       = 1        </P> -->
            <!-- Background temperature in Tnorm eV -->
            <P> T_bg      = 10         </P>

            <!-- Scaling factor for ICs -->
            <P> rc = 0.9 </P>
            <P> yc = 0 </P>           
            <P> rs = 0.100 </P>
            <P> ys = 0 </P>
            <P> sy = 0.10 </P>
            <P> sr = 0.10 </P>
            
            <!-- Implicit solve params -->
            <P> IterativeSolverTolerance  = 1.0E-5  </P>
            <P> NekNonlinSysMaxIterations = 30       </P>
            <P> NewtonRelativeIteTol      = 1.0E-10  </P>
            <P> NonlinIterTolRelativeL2   = 1.0E-10  </P>
            <P> LinSysRelativeTolInNonlin = 1.0E-02  </P>
        </PARAMETERS>

        <VARIABLES>
            <V ID="0"> n  </V>
        </VARIABLES>

        <BOUNDARYREGIONS>
            <B ID="0"> C[0] </B> <!-- Low x -->
        </BOUNDARYREGIONS>

        <BOUNDARYCONDITIONS>
            <REGION REF="0">
                <N VAR="n" VALUE="0.0" />
            </REGION>
        </BOUNDARYCONDITIONS>
        <FUNCTION NAME="InitialConditions">
            <E VAR="n"  DOMAIN="0" VALUE="1" />
        </FUNCTION>
        <FUNCTION NAME="MagneticMeanField">
            <F VAR="Bx,By,Bz"  FILE="B copy.pts"  />
        </FUNCTION>
    </CONDITIONS>

    <NESO>
        <SPECIES>
            <I NAME="D" FIELDS="n">
                <P> Mass = 2.0 </P>
                <P> Charge = 1.0 </P>
                <FUNCTION NAME="InitialConditions">
                    <E VAR="n"  DOMAIN="0" VALUE="1+exp((-(sqrt(x*x+z*z)-rc-rs)*(sqrt(x*x+z*z)-rc-rs)/(sr*sr))+(-(y-yc-ys)*(y-yc-ys)/(sy*sy)))" />  
                </FUNCTION>
            </I>
        </SPECIES>    
    </NESO>
</NEKTAR>
