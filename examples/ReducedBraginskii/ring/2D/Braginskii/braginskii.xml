<?xml version="1.0" encoding="utf-8" ?>
<NEKTAR>
    <COLLECTIONS DEFAULT="auto" />
    <EXPANSIONS>
       <E COMPOSITE="C[0]" NUMMODES="4" TYPE="MODIFIED" FIELDS="n,v,e" />
    </EXPANSIONS>

    <CONDITIONS>
        <SOLVERINFO>
            <I PROPERTY="EQTYPE"                       VALUE="ReducedBraginskii"/>
            <I PROPERTY="Projection"                   VALUE="DisContinuous" />
            <I PROPERTY="UpwindType"                   VALUE="MultiFieldUpwind"        />
            <I PROPERTY="TimeIntegrationMethod"        VALUE="IMEXOrder2"    />
            <I PROPERTY="LinSysIterSolverTypeInNonlin" VALUE="GMRES"         />
            <I PROPERTY="Preconditioner"               VALUE="Diagonal"/>
            <I PROPERTY="DiffusionAdvancement"         VALUE="Implicit"/>
            <I PROPERTY="AdvectionType"                VALUE="WeakDG"/>
        </SOLVERINFO>
            <TIMEINTEGRATIONSCHEME>
            <METHOD> DIRK </METHOD>
            <ORDER> 2 </ORDER>
        </TIMEINTEGRATIONSCHEME>

        <PARAMETERS>
            <!-- Conversion of mesh unit to m -->
            <P> mesh_length = 1 </P>
            <!-- Normalised temperature in eV -->
            <P> Tnorm = 1 </P>
            <!-- Normalised density in m^-3 -->
            <P> Nnorm = 1e18 </P>
            <!-- Normalised magnetic field in T -->
            <P> Bnorm = 1.0 </P>
            <!-- Time step in seconds -->
            <P> TimeStep = 0.00001 </P>
            <P> NumSteps = 1000 </P>
            <P> TFinal        = NumSteps*TimeStep </P>
            <P> IO_CheckSteps  = 1                </P>
            <P> IO_InfoSteps   = 1                </P>

            <P>LDGc11 = 100</P>

            <!-- Coulomb logarithm -->
            <P> lambda    = 13          </P>
            <P> k_c       = 3.19        </P>
            <!-- Background temperature in Tnorm eV -->
            <P> T_bg      = 10         </P>
            <!-- <P> k_par       = 0.00001        </P>
            <P> k_perp       = 0.0000001        </P>
            <P> kappa_par       = 0.00001        </P>
            <P> kappa_perp       = 0.0000001        </P> -->

            <!-- Scaling factor for ICs -->
            <P> rc = 2 </P>
            <P> ri = 0.5 </P>
            <P> ro = 1 </P>
            <P> yc = 0 </P>
            <P> rs = 0.75 </P>
            <P> ys = 0 </P>
            <P> sr = 0.1 </P>
            <P> sy = 0.1 </P>

            <!-- Implicit solve params -->
            <P> IterativeSolverTolerance  = 1.0E-6  </P>
            <P> NekNonlinSysMaxIterations = 30       </P>
            <P> NewtonRelativeIteTol      = 1.0E-10  </P>
            <P> NonlinIterTolRelativeL2   = 1.0E-10  </P>
            <P> LinSysRelativeTolInNonlin = 1.0E-02  </P>
        </PARAMETERS>

        <VARIABLES>
            <V ID="0"> n  </V>
            <V ID="1"> v  </V>
            <V ID="2"> e  </V>
        </VARIABLES>

        <BOUNDARYREGIONS>
            <B ID="1"> C[1] </B> <!-- Inner -->
            <B ID="2"> C[2] </B> <!-- Outer -->
        </BOUNDARYREGIONS>

        <BOUNDARYCONDITIONS>
            <REGION REF="1">
                <N VAR="n"  VALUE="0.0" />
                <N VAR="v"  VALUE="0" />
                <N VAR="e"  VALUE="0.0" />
            </REGION>
            <REGION REF="2">
                <N VAR="n"  VALUE="0.0" />
                <N VAR="v"  VALUE="0" />
                <N VAR="e"  VALUE="0.0" />
            </REGION>
        </BOUNDARYCONDITIONS>
        <FUNCTION NAME="InitialConditions">
            <E VAR="n"  DOMAIN="0" VALUE="1" />
            <E VAR="v"  DOMAIN="0" VALUE="0" />
            <E VAR="e"  DOMAIN="0" VALUE="1-0.1*(sqrt((x-rc)^2+(y-yc)^2)-ri)" />
            <!-- <E VAR="e"  DOMAIN="0" VALUE="1+0.1*exp((-(x-rc+rs)*(x-rc+rs)/(sr*sr))+(-(y-yc-ys)*(y-yc-ys)/(sy*sy)))" /> -->
        </FUNCTION>
        <FUNCTION NAME="MagneticField">
            <E VAR="Bx" VALUE="(y-yc)/sqrt((x-rc)*(x-rc)+(y-yc)*(y-yc))" />
            <E VAR="By" VALUE="-(x-rc)/sqrt((x-rc)*(x-rc)+(y-yc)*(y-yc))" />
            <E VAR="Bz" VALUE="10" />
        </FUNCTION>

    </CONDITIONS>
    <NESO>
        <SPECIES>
            <I NAME="D+" FIELDS="n,v,e">
                <P> Mass = 2.0 </P>
                <P> Charge = 1.0 </P>
                <FUNCTION NAME="InitialConditions">
                    <E VAR="n"  DOMAIN="0" VALUE="1+0.01*sin(4*2*PI*(sqrt((x-rc)^2+(y-yc)^2)-ri)/(ro-ri))*sin(16*ang(x-rc, y-yc))" />
                    <!-- <E VAR="n"  DOMAIN="0" VALUE="1-0.1*(sqrt((x-rc)^2+(y-yc)^2)-ri)" /> -->
                    <!-- <E VAR="n"  DOMAIN="0" VALUE="1" /> -->

                    <E VAR="v"  DOMAIN="0" VALUE="50-5*(sqrt((x-rc)^2+(y-yc)^2)-ri)" />
                    <!-- <E VAR="v"  DOMAIN="0" VALUE="0" /> -->
                    <!-- <E VAR="e"  DOMAIN="0" VALUE="1+0.1*exp((-(x-rc+rs)*(x-rc+rs)/(sr*sr))+(-(y-yc-ys)*(y-yc-ys)/(sy*sy)))" /> -->
                    <E VAR="e"  DOMAIN="0" VALUE="1-0.1*(sqrt((x-rc)^2+(y-yc)^2)-ri)" />
                </FUNCTION>
            </I>
        </SPECIES>
    </NESO>
</NEKTAR>

